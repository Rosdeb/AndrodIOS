{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "functions": {
    "api/[...route].mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...route]"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/android-icon-generator",
      "destination": "/website/android-icon-generator.html"
    },
    {
      "source": "/app-icon-generator",
      "destination": "/website/app-icon-generator.html"
    },
    {
      "source": "/app-icon-generator-free",
      "destination": "/website/app-icon-generator-free.html"
    },
    {
      "source": "/",
      "destination": "/website/index.html"
    }
  ]
}
